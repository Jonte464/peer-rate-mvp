{
  "manifest_version": 3,
  "name": "PeerRate – Verified Deal Trigger (MVP)",
  "version": "0.7.0",
  "description": "PeerRate extension med adapterstruktur för verifierade affärer och payload till rate.html.",
  "action": {
    "default_title": "PeerRate",
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://tradera.com/*",
    "https://www.tradera.com/*",
    "https://tradera.se/*",
    "https://www.tradera.se/*",
    "https://peerrate.ai/*",
    "https://www.peerrate.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://tradera.com/*",
        "https://www.tradera.com/*",
        "https://tradera.se/*",
        "https://www.tradera.se/*"
      ],
      "js": [
        "shared/dom.js",
        "shared/payload.js",
        "platforms/tradera.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}